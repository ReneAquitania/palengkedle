generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  imageUrl    String
  price       Float    
  gameDate    DateTime @unique 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}